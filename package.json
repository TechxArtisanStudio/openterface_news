{
  "name": "openterface_news",
  "type": "module",
  "version": "0.1.0",
  "siteLocale": "en",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "migrate:news": "node scripts/migrate-news-from-legacy.mjs",
    "normalize:media": "node scripts/normalize-article-media.mjs",
    "predev": "npm run migrate:news && npm run normalize:media",
    "prebuild": "npm run migrate:news && npm run normalize:media",
    "dev": "astro dev",
    "build": "astro build && node scripts/post-build-en-redirects.mjs",
    "preview": "astro preview",
    "test:smoke": "playwright test tests/smoke",
    "test:a11y": "playwright test tests/a11y",
    "test": "npm run test:smoke && npm run test:a11y"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.5",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "vite": "7.3.3"
  }
}
