---
import { formatArticleDate } from '../lib/news';
import { PRODUCT_LABELS, type ProductSlug } from '../config/products';
import type { SiteLocale } from '../lib/locale';

interface Props {
  locale: SiteLocale;
  title: string;
  date: Date;
  author?: string;
  product?: ProductSlug | null;
  category?: string;
  tags?: string[];
}

const { locale, title, date, author, product, category, tags = [] } = Astro.props;
---

<header class="article-header border-b border-gray-200 pb-6">
  {
    product && (
      <p class="text-sm font-semibold uppercase tracking-wide text-primary-dark">
        {PRODUCT_LABELS[product]}
      </p>
    )
  }
  <h1 class="mt-2 text-2xl font-bold leading-tight text-ink md:text-4xl">{title}</h1>
  <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-muted">
    <time datetime={date.toISOString()}>{formatArticleDate(date, locale)}</time>
    {author && <span>{author}</span>}
    {category && <span>{category}</span>}
  </div>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <li class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-muted">{tag}</li>
          ))
        }
      </ul>
    )
  }
</header>
