---
import { siteConfig } from '../config/site';
import { LOCALE_LABELS, localizedPath, localizedRssPath, switchLocalePath, type SiteLocale } from '../lib/locale';
import { t } from '../i18n/ui';
import { preserveQueryForLocaleSwitch } from '../lib/preserve-query';
import NewsHeaderBrand from './NewsHeaderBrand.astro';
import RssIconButton from './RssIconButton.astro';
import NewsSearch from './NewsSearch.astro';
import type { SearchEntry } from '../lib/search';

interface Props {
  locale: SiteLocale;
  currentPath: string;
  currentSearch?: string;
  searchIndex: SearchEntry[];
}

const { locale, currentPath, currentSearch = '', searchIndex } = Astro.props;
const preservedSearch = preserveQueryForLocaleSwitch(currentSearch);
const ui = t(locale);
const homeHref = localizedPath(locale);
const rssHref = localizedRssPath(locale);
const backAriaLabel = ui.nav.backToSiteAria ?? 'Back to Openterface website';
---

<header class="site-header site-header--news sticky top-0 z-50">
  <div class="site-header__inner site-header__inner--news">
    <div class="site-header__start site-header__start--news">
      <NewsHeaderBrand
        locale={locale}
        newsHomeHref={homeHref}
        backAriaLabel={backAriaLabel}
        opMarkSrc={siteConfig.headerOpMark}
        newsMarkSrc={siteConfig.headerNewsMark}
        newsMarkAlt={ui.nav.newsBadge}
      />
    </div>

    <div class="site-header__toolbar site-header__toolbar--news">
      <NewsSearch
        locale={locale}
        searchIndex={searchIndex}
        class="min-w-0 max-w-[9.5rem] sm:max-w-xs lg:max-w-sm"
      />

      <RssIconButton href={rssHref} label={ui.nav.rss} />

      <details class="locale-switcher relative">
        <summary
          class="site-header__icon-btn"
          aria-label={`Language: ${LOCALE_LABELS[locale]}`}
        >
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M4.545 6.714 4.11 8H3l1.862-5h1.284L8 8H6.833l-.435-1.286zm1.634-.736L5.5 3.956h-.049l-.679 2.022z"/>
            <path d="M0 2a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v3h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-3H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1h7a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1zm7.138 9.995q.289.451.63.846c-.748.575-1.673 1.001-2.768 1.292.178.217.451.635.555.867 1.125-.359 2.08-.844 2.886-1.494.777.665 1.739 1.165 2.93 1.472.133-.254.414-.673.629-.89-1.125-.253-2.057-.694-2.82-1.284.681-.747 1.222-1.651 1.621-2.757H14V8h-3v1.047h.765c-.318.844-.74 1.546-1.272 2.13a6 6 0 0 1-.415-.492 2 2 0 0 1-.94.31"/>
          </svg>
        </summary>
        <ul class="absolute right-0 top-full z-50 mt-1 min-w-[140px] rounded-lg border border-gray-200 bg-white py-1 shadow-lg">
          {
            Object.entries(LOCALE_LABELS).map(([loc, label]) => (
              <li>
                <a
                  href={switchLocalePath(currentPath, loc as SiteLocale, preservedSearch)}
                  data-locale-switch
                  class:list={[
                    'block px-3 py-2 text-sm hover:bg-brand-light hover:text-primary-dark',
                    loc === locale ? 'font-semibold text-primary-dark' : 'text-ink',
                  ]}
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </div>
  </div>
</header>

<script>
  import { applyPreservedQueryToLocaleLinks } from '../lib/preserve-query';

  applyPreservedQueryToLocaleLinks();
</script>

<style>
  .locale-switcher summary::-webkit-details-marker {
    display: none;
  }
</style>
