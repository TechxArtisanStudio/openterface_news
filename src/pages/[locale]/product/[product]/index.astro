---
import FeedLayout from '../../../../layouts/FeedLayout.astro';
import { productFeedProps } from '../../../../lib/feed-pages';
import { PRODUCTS, type ProductSlug } from '../../../../config/products';
import {
  INVALID_LOCALE_REDIRECT,
  isSiteLocale,
  localizedPath,
  SUPPORTED_LOCALES,
} from '../../../../lib/locale';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.flatMap((locale) =>
    PRODUCTS.filter((p) => p !== 'accessories').map((product) => ({
      params: { locale, product },
    })),
  );
}

const { locale: localeParam, product: productParam } = Astro.params;
if (!localeParam || !isSiteLocale(localeParam) || !productParam) {
  return Astro.redirect(INVALID_LOCALE_REDIRECT, 301);
}

if (localeParam === 'en') {
  return Astro.redirect(localizedPath('en', 'product', productParam), 301);
}

const product = productParam as ProductSlug;
const props = await productFeedProps(localeParam, product);
---

<FeedLayout
  locale={props.locale}
  title={props.title}
  description={props.description}
  articles={props.articles}
  basePath={props.basePath}
  showFilters={false}
/>
