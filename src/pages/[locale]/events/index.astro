---
import FeedLayout from '../../../layouts/FeedLayout.astro';
import { getNewsArticles } from '../../../lib/news';
import { isSiteLocale, SUPPORTED_LOCALES } from '../../../lib/locale';
import { t } from '../../../i18n/ui';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!localeParam || !isSiteLocale(localeParam)) {
  return Astro.redirect('/en/', 302);
}

const locale = localeParam;
const ui = t(locale);
const articles = (await getNewsArticles(locale)).filter((a) => a.data.channel === 'events');
const basePath = `/${locale}/events/`;
---

<FeedLayout
  locale={locale}
  title={ui.feed.eventsTitle}
  description={ui.feed.eventsDescription}
  articles={articles}
  basePath={basePath}
  showFilters={false}
/>
