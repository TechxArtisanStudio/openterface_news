---
import FeedLayout from '../../layouts/FeedLayout.astro';
import { homeFeedProps } from '../../lib/feed-pages';
import {
  INVALID_LOCALE_REDIRECT,
  isSiteLocale,
  localizedPath,
  SUPPORTED_LOCALES,
} from '../../lib/locale';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!localeParam || !isSiteLocale(localeParam)) {
  return Astro.redirect(INVALID_LOCALE_REDIRECT, 301);
}

if (localeParam === 'en') {
  return Astro.redirect(localizedPath('en'), 301);
}

const props = await homeFeedProps(localeParam, Astro.url);
---

<FeedLayout
  locale={props.locale}
  title={props.title}
  description={props.description}
  articles={props.articles}
  basePath={props.basePath}
  activeProduct={props.activeProduct}
  activeTopic={props.activeTopic}
  activeApp={props.activeApp}
  showAppFilters
/>
