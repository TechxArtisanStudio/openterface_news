---
import FeedLayout from '../../../layouts/FeedLayout.astro';
import { appsFeedProps } from '../../../lib/feed-pages';
import {
  INVALID_LOCALE_REDIRECT,
  isSiteLocale,
  localizedPath,
  SUPPORTED_LOCALES,
} from '../../../lib/locale';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const { locale: localeParam } = Astro.params;
if (!localeParam || !isSiteLocale(localeParam)) {
  return Astro.redirect(INVALID_LOCALE_REDIRECT, 301);
}

if (localeParam === 'en') {
  return Astro.redirect(localizedPath('en', 'apps'), 301);
}

const props = await appsFeedProps(localeParam, Astro.url);
---

<FeedLayout
  locale={props.locale}
  title={props.title}
  description={props.description}
  articles={props.articles}
  basePath={props.basePath}
  activeApp={props.activeApp}
  showProductFilters={false}
  showAppFilters={true}
/>
