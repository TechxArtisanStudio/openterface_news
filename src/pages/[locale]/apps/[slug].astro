---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getNewsArticles } from '../../../lib/news';
import { INVALID_LOCALE_REDIRECT, isSiteLocale, localizedPath } from '../../../lib/locale';

export async function getStaticPaths() {
  const entries = await getCollection('news', ({ data }) => !data.draft && data.channel === 'software');
  return entries.map((entry) => ({
    params: {
      locale: entry.data.locale,
      slug: entry.data.slug,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { locale: localeParam, slug: slugParam } = Astro.params;
if (!localeParam || !isSiteLocale(localeParam) || !slugParam) {
  return Astro.redirect(INVALID_LOCALE_REDIRECT, 301);
}

if (localeParam === 'en') {
  return Astro.redirect(localizedPath('en', 'apps', slugParam), 301);
}

const locale = localeParam;
const allArticles = await getNewsArticles(locale);
---

<ArticleLayout entry={entry} locale={locale} allArticles={allArticles} />
