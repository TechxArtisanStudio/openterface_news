---
import FeedLayout from '../../layouts/FeedLayout.astro';
import { appsFeedProps } from '../../lib/feed-pages';

const props = await appsFeedProps('en', Astro.url);
---

<FeedLayout
  locale={props.locale}
  title={props.title}
  description={props.description}
  articles={props.articles}
  basePath={props.basePath}
  activeApp={props.activeApp}
  showProductFilters={false}
  showAppFilters={true}
/>
