---
import { homeFeedRedirect } from '../../../lib/feed-redirects';
import { PRODUCTS, type ProductSlug } from '../../../config/products';

export async function getStaticPaths() {
  return PRODUCTS.filter((p) => p !== 'accessories').map((product) => ({
    params: { product },
  }));
}

const { product: productParam } = Astro.params;
const product = productParam as ProductSlug;

return Astro.redirect(homeFeedRedirect('en', Astro.url.searchParams, { product }), 301);
---
